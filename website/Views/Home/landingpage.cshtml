@{
}
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Webster Organisation</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            overflow-x: hidden;
        }

        .landing-page {
            height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1513828583688-c52646db42da?q=80&w=1920&auto=format&fit=crop');
            background-size: cover;
            background-position: center;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            padding: 20px;
        }

        .content-box {
            max-width: 800px;
        }

            .content-box h1 {
                font-size: 65px;
                font-weight: bold;
                margin-bottom: 20px;
            }

            .content-box p {
                font-size: 20px;
                line-height: 1.8;
                margin-bottom: 35px;
            }

        .btn-custom {
            padding: 14px 35px;
            border: none;
            border-radius: 40px;
            font-size: 18px;
            font-weight: bold;
            margin: 10px;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .login-btn {
            background: #ffc107;
            color: black;
        }

            .login-btn:hover {
                background: white;
                color: black;
            }

        .explore-btn {
            background: transparent;
            border: 2px solid white;
            color: white;
        }

            .explore-btn:hover {
                background: white;
                color: black;
            }

        .about-section {
            padding: 80px 20px;
            background: #f8f9fa;
            text-align: center;
        }

            .about-section h2 {
                font-size: 45px;
                margin-bottom: 25px;
                font-weight: bold;
            }

            .about-section p {
                font-size: 19px;
                max-width: 900px;
                margin: auto;
                line-height: 1.9;
            }

        .cards-section {
            padding: 70px 20px;
        }

        .feature-card {
            background: white;
            padding: 35px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: 0.3s;
            height: 100%;
        }

            .feature-card:hover {
                transform: translateY(-10px);
            }

            .feature-card h3 {
                margin-bottom: 15px;
                font-weight: bold;
            }

        footer {
            background: #111;
            color: white;
            text-align: center;
            padding: 20px;
        }

    </style>

</head>

<body>

    <!-- Landing Page -->
    <section class="landing-page">

        <div class="content-box">

            <h1>Webster Organisation</h1>

            <p>
                The leading organization in the world of Oil-Gas Company.
                Webster Organisation has branches throughout the world and
                partnerships with multinational companies. We provide online
                recruitment and testing systems for talented job seekers.
            </p>

            <!-- Buttons -->
            @* <a href="AdminLogin.aspx" class="btn-custom login-btn">
                Login
            </a> *@
            <a class="btn btn-success" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>



            <a href="#about" class="btn-custom explore-btn">
                Explore More
            </a>

        </div>

    </section>

    <!-- About Section -->
    <section id="about" class="about-section">

        <h2>About Webster Organisation</h2>

        <p>
            Webster Organisation provides advanced recruitment systems where
            candidates can apply online, appear in online tests, and qualify
            for further recruitment rounds based on their performance.
            The company focuses on innovation, career development, and
            global employment opportunities in the Oil & Gas industry.
        </p>

    </section>

    <!-- Features -->
    <section class="cards-section">

        <div class="container">

            <div class="row g-4">

                <div class="col-md-4">
                    <div class="feature-card text-center">

                        <h3>Online Recruitment</h3>

                        <p>
                            Candidates can register and apply for jobs online easily.
                        </p>

                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card text-center">

                        <h3>Online Test</h3>

                        <p>
                            Attend online assessments and qualify for further rounds.
                        </p>

                    </div>
                </div>

                <div class="col-md-4">
                    <div class="feature-card text-center">

                        <h3>Admin Dashboard</h3>

                        <p>
                            Admin can manage jobs, candidates, and test results efficiently.
                        </p>

                    </div>
                </div>

            </div>

        </div>

    </section>

    <!-- Footer -->
    <footer>

        <p>
            © 2026 Webster Organisation | All Rights Reserved
        </p>

    </footer>

</body>
</html>
```
