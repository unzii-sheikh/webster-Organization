@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Login - Webster Organisation</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
            background: #f4f7fc;
            font-family: 'Segoe UI', sans-serif;
            height: 100vh;
        }

        .login-container {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-card {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .title {
            font-size: 35px;
            font-weight: bold;
            color: #0d6efd;
        }

        .subtitle {
            color: gray;
            margin-bottom: 25px;
        }

        .form-control {
            height: 50px;
            border-radius: 12px;
        }

        .btn-login {
            height: 50px;
            border-radius: 12px;
            font-size: 18px;
            font-weight: 600;
        }

        .form-links a {
            text-decoration: none;
            color: #0d6efd;
        }

            .form-links a:hover {
                text-decoration: underline;
            }

        .external-login button {
            margin: 5px;
            border-radius: 10px;
        }

        .login-container {
            margin-top: 10px;
        }

        .login-container {
            min-height: 50vh;
            display: flex;
            justify-content: center;
            align-items: start;
            padding-top: 10px;
        }

    </style>
</head>

<body>

    <div class="container login-container">

        <br />
        <br />
        <br />
        <br />
        <br />
        <div class="row w-100 justify-content-center">

            <!-- Login Form -->
            <div class="col-lg-5 col-md-7">

                <div class="login-card">

                    <div class="text-center mb-4">
                        <h1 class="title">Webster Organisation</h1>
                        <p class="subtitle">
                            Sign in to access your dashboard
                        </p>
                    </div>

                    <section>

                        <form id="account" method="post">

                            <div asp-validation-summary="ModelOnly"
                                 class="text-danger mb-3"
                                 role="alert">
                            </div>

                            <!-- Email -->
                            <div class="form-floating mb-3">

                                <input asp-for="Input.Email"
                                       class="form-control"
                                       autocomplete="username"
                                       aria-required="true"
                                       placeholder="name@example.com" />

                                <label asp-for="Input.Email">
                                    Email Address
                                </label>

                                <span asp-validation-for="Input.Email"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- Password -->
                            <div class="form-floating mb-3">

                                <input asp-for="Input.Password"
                                       class="form-control"
                                       autocomplete="current-password"
                                       aria-required="true"
                                       placeholder="password" />

                                <label asp-for="Input.Password">
                                    Password
                                </label>

                                <span asp-validation-for="Input.Password"
                                      class="text-danger">
                                </span>

                            </div>

                            <!-- Remember -->
                            <div class="checkbox mb-3">

                                <label asp-for="Input.RememberMe"
                                       class="form-label">

                                    <input class="form-check-input"
                                           asp-for="Input.RememberMe" />

                                    @Html.DisplayNameFor(m => m.Input.RememberMe)

                                </label>

                            </div>

                            <!-- Button -->
                            <div class="d-grid mb-3">

                                <button id="login-submit"
                                        type="submit"
                                        class="btn btn-primary btn-login">

                                    Log in

                                </button>

                            </div>

                            <!-- Links -->
                            <div class="form-links text-center">

                                <p>
                                    <a id="forgot-password"
                                       asp-page="./ForgotPassword">

                                        Forgot your password?

                                    </a>
                                </p>

                                <p>
                                    <a asp-page="./Register"
                                       asp-route-returnUrl="@Model.ReturnUrl">

                                        Register as a new user

                                    </a>
                                </p>

                                <p>
                                    <a id="resend-confirmation"
                                       asp-page="./ResendEmailConfirmation">

                                        Resend email confirmation

                                    </a>
                                </p>

                            </div>

                        </form>

                    </section>

                    <!-- External Login -->
                    <section class="mt-4">

                        <div class="text-center mb-3">
                            
                        </div>

                        <hr />

                        @{

                            if ((Model.ExternalLogins?.Count ?? 0) == 0)
                            {
                                <div class="text-center text-muted">

                                    No external authentication services configured.

                                </div>
                            }
                            else
                            {
                                <form id="external-account"
                                      asp-page="./ExternalLogin"
                                      asp-route-returnUrl="@Model.ReturnUrl"
                                      method="post"
                                      class="external-login text-center">

                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        <button type="submit"
                                                class="btn btn-outline-primary"
                                                name="provider"
                                                value="@provider.Name"
                                                title="Log in using your @provider.DisplayName account">

                                            @provider.DisplayName

                                        </button>
                                    }

                                </form>
                            }

                        }

                    </section>

                </div>

            </div>

        </div>

    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }

</body>

</html>